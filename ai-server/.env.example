# CA Final AI Proxy - Environment Variables
# Copy this to .env and fill in your keys.

# Provider API keys
GEMINI_API_KEY=AIzaSyxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxx
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxx

# Server config
PORT=3721

# Optional ranked model overrides (comma-separated). Leave blank to use the built-in cascade:
# Gemini first: gemini-3.5-flash -> gemini-3.1-flash-lite -> gemini-flash-latest -> gemini-2.5-flash -> gemini-2.5-flash-lite
#   (the latter three are known-good fallbacks in case the requested names are not served by the API)
# Groq next: openai/gpt-oss-120b -> qwen/qwen3-32b -> openai/gpt-oss-20b -> llama-3.3-70b-versatile -> llama-3.1-8b-instant -> compound models
# Models the API reports as not found are remembered and skipped for the rest of the session.
GEMINI_MODELS=
GROQ_MODELS=
MISTRAL_MODELS=
OPENROUTER_MODELS=
